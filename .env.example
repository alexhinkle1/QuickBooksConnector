# Local REST API port.
PORT=3000

# Name shown in QuickBooks Desktop Integrated Application permissions.
QB_APP_NAME=QuickBooks Desktop Adapter

# Leave empty to attach to the currently open QuickBooks company.
# Or set an absolute .qbw path after granting automatic login in QuickBooks.
# Example:
# QB_COMPANY_FILE=C:\Users\Public\Documents\Intuit\QuickBooks\Company Files\YourCompany.qbw
QB_COMPANY_FILE=

# Use info for normal operation. Use debug while troubleshooting QBXML.
LOG_LEVEL=info
